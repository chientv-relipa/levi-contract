# Copy to .env and fill in. Used by the e2e tests (tests-ts/).
#
# Operator/relayer key in Sui bech32 form (starts with "suiprivkey1...").
# Export from the CLI keystore:  sui keytool export --key-identity <alias-or-address>
# This wallet must be the operator that ran `initialize` (holds AdminCap + RelayerCap)
# and have some testnet SUI for gas.
OPERATOR_SECRET_KEY=suiprivkey1...

# Optional: override the deployed addresses (defaults to the testnet deployment).
# LEVI_PACKAGE_ID=0x...
# LEVI_CONFIG_ID=0x...
# LEVI_REGISTRY_ID=0x...
# LEVI_ADMIN_CAP_ID=0x...
# LEVI_RELAYER_CAP_ID=0x...

# Sui fullnode (defaults to testnet).
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
